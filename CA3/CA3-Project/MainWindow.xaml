<Window x:Class="CA3_S00274698_ThiagoBraz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CA3_S00274698_ThiagoBraz"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <TabControl>
        <TabItem Header="New Booking">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Category -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: Check-in -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Check-out -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: Search button -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: Label "Available Rooms:" -->
                    <RowDefinition Height="150"/>
                    <!-- 5: ListBox -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: Room details -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7: Guest Name -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8: Guest Email -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9: Book button -->
                    <RowDefinition Height="*"/>
                    <!-- 10: Spacer -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Category selection -->
                <Label Grid.Row="0" Grid.Column="0" Content="Category:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CategoryComboBox" Grid.Row="0" Grid.Column="1" Width="200"
                      HorizontalAlignment="Left" Margin="0,5,0,5"/>

                <!-- Date selection -->
                <Label Grid.Row="1" Grid.Column="0" Content="Check-in Date:" VerticalAlignment="Center"/>
                <DatePicker x:Name="CheckInDate" Grid.Row="1" Grid.Column="1" Width="200"
                        HorizontalAlignment="Left" Margin="0,5,0,5" DisplayDateStart="{x:Static sys:DateTime.Today}"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Check-out Date:" VerticalAlignment="Center"/>
                <DatePicker x:Name="CheckOutDate" Grid.Row="2" Grid.Column="1" Width="200"
                        HorizontalAlignment="Left" Margin="0,5,0,5" DisplayDateStart="{x:Static sys:DateTime.Today}"/>

                <!-- Search button -->
                <Button Grid.Row="3" Grid.Column="0" Content="Search"
                    Click="SearchButton_Click" Margin="0,10,0,10" Width="100"
                    HorizontalAlignment="Left"/>

                <!-- Label for available rooms -->
                <Label Grid.Row="4" Grid.Column="0" Content="Available Rooms:"
                   FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>

                <!-- Available rooms list -->
                <ListBox x:Name="RoomsList" Grid.Row="5" Grid.Column="0"
     Margin="0,0,10,0" SelectionChanged="RoomsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="Category"/>
                                        <Binding Path="RoomNumber"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Room details -->
                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Image x:Name="RoomTypeImage" Height="100" Width="100" Margin="0,0,10,0"/>
                    <TextBlock x:Name="RoomDetails"
               TextWrapping="Wrap"
               Background="LightCyan"
               Padding="10"
               Height="100"
               Width="250"
               VerticalAlignment="Top"/>
                </StackPanel>

                <!-- Guest info -->
                <Label Grid.Row="7" Grid.Column="0" Content="Guest Name:" VerticalAlignment="Center"/>
                <TextBox x:Name="GuestNameTextBox" Grid.Row="7" Grid.Column="1"
                     Margin="0,5,0,5" Width="300" HorizontalAlignment="Left"/>

                <Label Grid.Row="8" Grid.Column="0" Content="Guest Email:" VerticalAlignment="Center"/>
                <TextBox x:Name="GuestEmailTextBox" Grid.Row="8" Grid.Column="1"
                     Margin="0,5,0,5" Width="300" HorizontalAlignment="Left"/>

                <!-- Book button -->
                <Button Grid.Row="9" Grid.Column="0" Content="Book"
                    Click="BookButton_Click" Margin="0,10,0,0" Width="100"
                    HorizontalAlignment="Left"/>
            </Grid>
        </TabItem>

        <!-- All Rooms Tab -->
        <TabItem Header="All Rooms">
            <DataGrid x:Name="AllRoomsGrid" AutoGenerateColumns="True" Margin="10"/>
        </TabItem>

        <!-- Existing Bookings Tab -->
        <TabItem Header="Bookings">
            <DataGrid x:Name="BookingsGrid" AutoGenerateColumns="False" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Guest Name" Binding="{Binding GuestName}" Width="*"/>
                    <DataGridTextColumn Header="Guest Email" Binding="{Binding GuestEmail}" Width="*"/>
                    <DataGridTextColumn Header="Room Number" Binding="{Binding Room.RoomNumber}" Width="*"/>
                    <DataGridTextColumn Header="Check In" Binding="{Binding CheckInDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                    <DataGridTextColumn Header="Check Out" Binding="{Binding CheckOutDate, StringFormat=dd/MM/yyyy}" Width="*"/>
                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete" Click="DeleteBooking_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>
    </TabControl>
</Window>
