<Window x:Class="OOSD2_CA1___Thiago_Braz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOSD2_CA1___Thiago_Braz"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Window.Resources>
        <local:EnumBooleanConverter x:Key="EnumBooleanConverter"/>
    </Window.Resources>

    <Grid>
        <!--Creation of rows-->
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <!--Creation of columns-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"></ColumnDefinition>
            <ColumnDefinition Width="5*"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <!--Header section with titles for Ward, Patients and Details-->
        <TextBlock Name="WardHeader" Width="300" Grid.Row="0" Grid.Column="0" Text="{Binding WardHeaderText}" Background="Green" Foreground="Black" TextAlignment="Center"  FontWeight="Bold" FontSize="20" Padding="10"></TextBlock>
        <TextBlock Name="PatientsHeader" Width="300" Grid.Row="0" Grid.Column="1" Text="Patients" Background="Green" Foreground="Black" TextAlignment="Center"  FontWeight="Bold" FontSize="20" Padding="10"></TextBlock>
        <TextBlock Name="DetailsHeader" Width="180" Grid.Row="0" Grid.Column="2" Text="Details" Background="Green" Foreground="Black" TextAlignment="Center"  FontWeight="Bold" FontSize="20" Padding="10"></TextBlock>

        <!--List of Wards-->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
            <ListBox Name="wardsList" ItemsSource="{Binding Wards}" SelectionChanged="wardsList_SelectionChanged" Height="Auto"></ListBox>
        </StackPanel>
        
        <!--List of Patients-->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
            <ListBox Name="patientsList" Height="Auto" SelectionChanged="patientsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding}" FontSize="16" VerticalAlignment="Center"></TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
        
        <!--Patients Details section-->
        <StackPanel Grid.Row="1" Grid.Column="2" Margin="5" Name="detailsPanel" Visibility="Collapsed">
            <TextBlock Name="detailsName" FontSize="20" FontWeight="Bold" Margin="5" TextAlignment="Center"></TextBlock>
            <Image Name="detailsBloodImage" Width="50" Height="50" Margin="5"></Image>
            
        </StackPanel>
        
        <!--Expander for adding a new ward-->
        <Expander Header="Add new ward" Grid.Row="1" Grid.Column="0" VerticalAlignment="Bottom" Grid.RowSpan="2">
            <StackPanel Margin="5" DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock Text="Ward Name:"/>
                    <TextBox Text="{Binding NewWardName, UpdateSourceTrigger=PropertyChanged}" Width="200"  Margin="10,-12,0,0"/>
                </StackPanel>
                <StackPanel Orientation="vertical" Margin="0,20,0,0">
                    <TextBlock Text="Capacity:" Margin="0,12,0,0"></TextBlock>
                    <Slider x:Name="SliderCapacity" ValueChanged="slider_ValueChanged" Width="180" Margin="5,-22,0,0" Minimum="1" Maximum="10" SmallChange="1" VerticalAlignment="Top" TickPlacement="TopLeft"></Slider>
                    <TextBlock Name="WardCapacity" HorizontalAlignment="Left" TextWrapping="Wrap"  Margin="250,-18,0,0"/>
                    <!--Button to add a new ward-->
                    <Button Content="Add Ward" IsEnabled="{Binding IsAddWardEnable}" Click="AddWard" Width="300" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0" Grid.Row="2" Grid.Column="0" Background="Green" VerticalAlignment="Bottom"/>
                </StackPanel>
            </StackPanel>
        </Expander>
        
        <!--Expander for adding a new patient-->
        <Expander Header="Add a new patient" Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Grid.RowSpan="2">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <TextBlock Text="Name:"/>
                    <TextBox Text="{Binding NewPatientName, UpdateSourceTrigger=PropertyChanged}" Margin="10,-12,0,0" Width="200"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock Text="DOB: " Margin="0,5,10,0" />
                    <DatePicker SelectedDate="{Binding NewPatientDateOfBirth, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="0,40,0,0">
                    <TextBlock Text="Blood Type: " Margin="0,-20,0,0"/>
                    <RadioButton Content="A" IsChecked="{Binding Path=NewPatientBloodType, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=A}" GroupName="BloodType" Margin="65,-20,0,0" />
                    <RadioButton Content="B" IsChecked="{Binding Path=NewPatientBloodType, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=B}" GroupName="BloodType" Margin="105,-20,0,0" />
                    <RadioButton Content="AB" IsChecked="{Binding Path=NewPatientBloodType, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=AB}" GroupName="BloodType" Margin="145,-20,0,0"/>
                    <RadioButton Content="O" IsChecked="{Binding Path=NewPatientBloodType, Converter={StaticResource EnumBooleanConverter}, ConverterParameter=O}" GroupName="BloodType" Margin="185,-20,0,0"/>
                    <!--Button to add a new patient-->
                    <Button Content="Add Patient" IsEnabled="{Binding IsAddPatientEnable}" Click="AddPatient" Width="300" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="5" Grid.Row="2" Grid.Column="1" Background="Green" VerticalAlignment="Bottom"/>
                </StackPanel>
            </StackPanel> 
        </Expander>

        <!--Stack Panel for Load and Save buttons-->
        <StackPanel Grid.Row="2" Grid.Column="2">
            <Button Content="Load" Click="LoadButton_Click" Width="180" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="5" Grid.Row="2" Grid.Column="0" Background="Green" VerticalAlignment="Top"/>
            <Button Content="Save" Click="SaveButton_Click" Width="180" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="5" Grid.Row="2" Grid.Column="0" Background="Green" VerticalAlignment="Top"/>
        </StackPanel>
    </Grid>
</Window>
